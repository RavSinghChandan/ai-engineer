# OpenAI API Configuration
# Copy this file to .env and add your actual API keys
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Configuration (used for large token requests >= 2000 tokens)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Token routing threshold (default: 2000)
# Requests with fewer tokens use OpenAI; requests at or above use DeepSeek
LLM_TOKEN_THRESHOLD=50

