# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepSeek API — used for large token requests (>= LLM_TOKEN_THRESHOLD)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Token routing threshold (default 2000 tokens)
LLM_TOKEN_THRESHOLD=50

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=langchain-ai-service
LANGCHAIN_API_KEY=your-langsmith-api-key-here
